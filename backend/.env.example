# DB Creator — Environment Template
# Copy to .env and fill in CHANGE_ME values before running.
#
# Generate FERNET_KEY:  python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# Generate JWT_SECRET:  python -c "import secrets; print(secrets.token_hex(32))"
# Generate ADMIN_KEY:   python -c "import secrets; print(secrets.token_hex(16))"

# Database (local Docker defaults — safe for local dev, change for production)
DATABASE_URL=postgresql+asyncpg://dbcreator:dbcreator@localhost:5432/dbcreator
TEST_DATABASE_URL=postgresql+asyncpg://dbcreator:dbcreator@localhost:5432/dbcreator_test
REDIS_URL=redis://localhost:6379/0

# REQUIRED — encrypts stored SSH keys. Generate a new value per deployment.
FERNET_KEY=CHANGE_ME

# REQUIRED — signs JWT tokens. Generate a new value per deployment.
JWT_SECRET=CHANGE_ME

# Admin key for /admin/* endpoints.
ADMIN_KEY=CHANGE_ME

# Initial admin user password — set before first run.
DEFAULT_ADMIN_PASSWORD=CHANGE_ME

DEBUG=false
ENVIRONMENT=development
